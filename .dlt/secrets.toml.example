# Socrata API app token for data.texas.gov
# Register at: https://data.texas.gov/profile/edit/developer_settings
[sources.txwc]
application_token = "your_socrata_app_token_here"

# UMLS/NLM API key for VSAC value sets
# Register at: https://uts.nlm.nih.gov/uts/signup-login
[sources.vsac]
api_key = "your_umls_api_key_here"
